levet strammet, så private parkeringsselskaber ikke længere må eftersende opkrævninger – heller ikke i undtagelsestilfælde – og at selskabernes adgang til Motorregisteret monitoreres. \n\nPartierne hilser debatten om forbrugerbeskyttelse i forhold til private parkeringsselskaber velkommen og følger fortsat området tæt.","sag_short_title":"Om initiativer, der kan styrke forbrugerbeskyttelsen på parkeringsområdet.","sag_type_id":9,"sag_type":"Forslag til vedtagelse","sag_status_id":17,"sag_status":"Vedtaget","sag_category_id":null,"sag_category":null,"fremsatundersagid":104133,"deltundersagid":null,"actors":[{"actor_id":20820,"name":"Carl Andersen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":21194,"name":"Joachim Hoffmann-Petersen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":20350,"name":"Nick Zimmermann","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":20389,"name":"Peter Have","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":180,"name":"Peter Juel-Jensen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":18726,"name":"Stinus Lindgreen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":201,"name":"Thomas Jensen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":21243,"name":"Transportudvalget","short_name":"TRU","type_id":3,"type":"Udvalg","role_id":9,"role":"Relevant for"}],"law_followup":{"law_number":null,"law_number_date":null,"decision_date":null,"decision_result_code":null,"decision_text":null,"retsinformation_url":null},"steps":[{"sagstrin_id":272671,"date":"2026-02-19","title":"Fremsættelse","type":"Fremsættelse","status":"Fremsat","vote_ids":[],"documents":[],"agenda