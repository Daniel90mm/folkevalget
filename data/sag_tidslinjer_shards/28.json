ument_status_id":1,"document_status":"Endeligt","document_category_id":55,"document_category":"Betænkning m.v.","document_actors":[],"question_chain":{"askers":[],"responders":[]}},{"document_id":1204016,"title":"Efter afstemningen i Folketinget ved 2. behandling den 15. januar 2026","number":null,"date":"2026-01-15","role":"På sagstrin","url":"https://www.ft.dk/ripdf/samling/20251/lovforslag/l84/20251_l84_efter_2behandling.pdf","format":"PDF","variant_code":"P","is_omtryk":false,"omtryk":[],"document_type_id":21,"document_type":"Forslagstekst","document_status_id":1,"document_status":"Endeligt","document_category_id":20,"document_category":"Optryk efter 2.beh","document_actors":[],"question_chain":{"askers":[],"responders":[]}},{"document_id":1203753,"title":"Betænkning afgivet af Socialudvalget den 13. januar 2026","number":null,"date":"2026-01-14","role":"På sagstrin","url":"https://www.ft.dk/ripdf/samling/20251/lovforslag/l84/20251_l84_betaenkning.pdf","format":"PDF","variant_code":"P","is_omtryk":false,"omtryk":[],"document_type_id":21,"document_type":"Forslagstekst","document_status_id":1,"document_status":"Endeligt","document_category_id":55,"document_category":"Betænkning m.v.","document_actors":[],"question_chain":{"askers":[],"responders":[]}}],"related_cases":[],"emneord":{"sag":[{"id":33273,"emneord":"Forsikringsvæsen 29","type_id":4,"type":"Lovsagsnavn"},{"id":33155,"emneord":"udsatte voksne","type_id":1,"type":"Sagsområde"}],"dokumenter":[{"id":33155,"emneord":"udsatte voksne","type_id":1,"type":"Sagsområde"},{"id":33609,"emneord":"betænkning","type_id":2,"type":"Ukontrolleret"}],"samlet":[{"id":33273,"emneord":"Forsikringsvæsen 29","type_id":4,"type":"Lovsagsnavn"},{"id":33155,"emneord":"udsatte voksne","type_id":1,"type":"Sagsområde"},{"id":33609,"emneord":"betænkning","type_id":2,"type":"Ukontrolleret"}]}},{"sag_id":104540,"sag_number":"V 21","sag_title":"Folkeskolen skal bl.a. sikre, at børn lærer at læse, skrive og regne i trygge rammer. Det kræver tilstrækkeligt med økonomi. Derfor hilser partierne debatten om folkeskolens økonomi velkommen. \n\nFolkeskolens økonomi fastlægges konkret i kommunernes årlige budgetter. Partierne bakker op om det kommunale selvstyre. Partierne noterer sig, at regeringen har indgået flere ambitiøse kommuneøkonomiaftaler med KL, senest for 2026, der løftede den kommunale serviceramme med 3,2 mia. kr. Kommunerne kan bl.a. anvende disse løft til forbedringer af folkeskolen. \n\nPartierne kan konstatere, at der i dag bruges flere penge pr. elev i folkeskolen end tidligere. \n\nPartierne noterer sig derudover, at et flertal på Christiansborg de seneste år har styrket folkeskolen, herunder økonomisk, med flere tiltag. Bl.a. med Folkeskolens Kvalitetsprogram, flere bøger, juniormesterlære og intensiv undervisning i dansk og matematik. I forbindelse med finansloven for 2026 har regeringen og Det Konservative Folkeparti derudover aftalt at styrke indsatsen mod langvarigt skolefravær.","sag_short_title":"Om, hvorvidt udgifter til folkeskolen bør følge samfundets generelle velstandsudvikling.","sag_type_id":9,"sag_type":"Forslag til vedtagelse","sag_status_id":17,"sag_status":"Vedtaget","sag_category_id":null,"sag_category":null,"fremsatundersagid":104121,"deltundersagid":null,"actors":[{"actor_id":168,"name":"Anni Matthiesen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":20357,"name":"Lise Bertelsen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":20386,"name":"Rasmus Lund-Nielsen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":20363,"name":"Sara Emil Baaring","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":21263,"name":"Børne- og Undervisningsudvalget","short_name":"BUU","type_id":3,"type":"Udvalg","role_id":9,"role":"Relevant for"}],"law_followup":{"law_number":null,"law_number_date":null,"decision_date":null,"decision_result_code":null,"decision_text":null,"retsinformation_url":null},"steps":[{"sagstrin_id":272235,"date":"2026-02-03","title":"Fremsættelse","type":"Fremsættelse","status":"Fremsat","vote_ids":[],"documents":[],"agenda_items":[]},{"sagstrin_id":272236,"date":"2026-02-05","title":"Behandling","type":"Behandling","status":"Behandlet","vote_ids":[10554],"documents":[],"agenda_items":[]}],"documents":[],"related_cases":[{"sag_id":104121,"sag_number":"F 7","sag_title":"Mener regeringen, at børn i folkeskolen skal opleve velstandsstigningen i samfundet, og deraf, at udgifter til folkeskolen bør følge samfundets generelle velstandsudvikling?","sag_short_title":"Om, hvorvidt udgifter til folkeskolen bør følge samfundets generelle velstandsudvikling.","relations":["Fremsat under"]}],"emneord":{"sag":[{"id":33318,"emneord":"folkeskolen","type_id":1,"type":"Sagsområde"}],"dokumenter":[],"samlet":[{"id":33318,"emneord":"folkeskolen","type_id":1,"type":"Sagsområde"}]}},{"sag_id":104700,"sag_number":"V 24","sag_title":"Folketingets partier konstaterer, at vælgernes tillid til det lokale demokrati er helt afgørende. \n\nMed det borgerlige ombud har man pligt til at modtage valget, men dog med mulighed for at blive fritaget i visse situationer. Medlemskab af Folketinget og Europa-Parlamentet er derimod ikke et borgerligt ombud. Partierne er enige om, at det borgerlige ombud er udtryk for en hensigtsmæssig balance mellem forskellige krydsende hensyn. Folketingets partier lægger derfor ikke op til at ændre reglerne om det borgerlige ombud ved kommunal- og regionalvalg.\n\nPartierne er enige om, at det er afgørende for tilliden til demokratiet, at kandidater ved opstilling til valg overholder valgbarhedskravene, og partierne noterer sig, at der er regler om straf i både CPR-loven og straffeloven, der efter omstændighederne vil kunne finde anvendelse på forsætlige brud herpå.","sag_short_title":"Om efterlevelse af det borgerlige ombud ved lokale valg.","sag_type_id":9,"sag_type":"Forslag til vedtagelse","sag_status_id":17,"sag_status":"Vedtaget","sag_category_id":null,"sag_category":null,"fremsatundersagid":104249,"deltundersagid":null,"actors":[{"actor_id":16503,"name":"Anne Paulin","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":18699,"name":"Christoffer Aagaard Melson","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":20962,"name":"Claus Jørgensen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":18693,"name":"Mai Villadsen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":20384,"name":"Nanna W. Gotfredsen","short_name":null,"type_id":5,"type":"Person","role_id":16,"role":"Forslagsstiller (priv.)"},{"actor_id":21251,"name":"Indenrigsudvalget","short_name":"INU","type_id":3,"type":"Udvalg","role_id":9,"role":"Relevant for"}],"law_followup":{"law_number":null,"law_number_date":null,"decision_date":null,"decision_result_code":null,"decision_text":null,"retsinformation_url":null},"steps":[{"sagstrin_id":272647,"date":"2026-02-19","title":"Fremsættelse","type":"Fremsættelse","status":"Fremsat","vote_ids":[],"documents":[],"agenda_items":[]},{"sagstrin_id":272648,"date":"2026-02-26","title":"Behandling","type":"Behandling","status":"Behandlet","vote_ids":[10569],"documents":[],"agenda_items":[]}],"documents":[],"related_cases":[{"sag_id":104249,"sag_number":"F 10","sag_title":"Mener regeringen, at ånden i det borgerlige ombud efterleves tilfredsstillende ved lokale valg, når politikere kort efter et valg frasiger sig deres hverv med svage eller politiske begrundelser, og når det samtidig forholder sig således, at mulighederne for at sanktionere forsætlige brud på valgbarhedskrav er begrænsede, og agter ministeren på den baggrund at overveje initiativer, der kan styrke vælgernes tillid til det lokale demokrati, herunder ved at skærpe reglerne om borgerligt ombud?","sag_short_title":"Om efterlevelse af det borgerlige ombud ved lokale valg.","relations":["Fremsat under"]}],"emneord":{"sag":[{"id":33081,"emneord":"valg og folkeafstemninger","type_id":1,"type":"Sagsområde"}],"dokumenter":[],"samlet":[{"id":33081,"emneord":"valg og folkeafstemninger","type_id":1,"type":"Sagsområde"}]}}]